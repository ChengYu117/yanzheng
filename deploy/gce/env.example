# Copy this file to deploy/gce/.env before running the GCE scripts.

DATA_ROOT=/mnt/disks/data
MODEL_DIR=${DATA_ROOT}/models/Llama-3.1-8B
HF_HOME=${DATA_ROOT}/hf-cache
OUTPUT_ROOT=${DATA_ROOT}/outputs

VENV_DIR=${HOME}/nlp-re/.venv
PYTHON_BIN=python3.11
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu124
# Leave CONDA_ENV_NAME empty to use VENV_DIR. Set it to reuse an existing
# conda environment, for example CONDA_ENV_NAME=qwen-env-py311.
CONDA_ENV_NAME=
# Optional. Usually detected automatically by `conda info --base`.
CONDA_BASE=

# Current main experiment defaults. Keep cloud wrappers aligned with
# the local experiment guide unless you intentionally run another dataset.
DATA_DIR=data/mi_re
DEVICE=cuda
CHECKPOINT_TOPK_SEMANTICS=hard

# Hugging Face access for downloading the gated base model.
HF_TOKEN=
MODEL_HF_REPO_ID=meta-llama/Llama-3.1-8B
MODEL_REVISION=main
# Optional Hugging Face mirror. For mainland China cloud servers, use:
# HF_ENDPOINT=https://hf-mirror.com
HF_ENDPOINT=
HF_HUB_DOWNLOAD_TIMEOUT=60
HF_HUB_ETAG_TIMEOUT=60
HF_HUB_DOWNLOAD_MAX_WORKERS=4

SAE_OUTPUT_DIR=${OUTPUT_ROOT}/sae_eval_full
CAUSAL_OUTPUT_DIR=${OUTPUT_ROOT}/causal_validation_full

SAE_BATCH_SIZE=4
SAE_MAX_SEQ_LEN=128
CAUSAL_BATCH_SIZE=4
CAUSAL_MAX_SEQ_LEN=128
CAUSAL_LAMBDAS="0.5 1.0 1.5 2.0"

# Optional AI judge settings.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
# Use single quotes in .env when setting JSON, for example:
# OPENAI_EXTRA_BODY_JSON='{"enable_thinking":false}'
OPENAI_EXTRA_BODY_JSON=
JUDGE_TOP_LATENTS=20
JUDGE_TOP_N=10
JUDGE_CONTROL_N=5
JUDGE_GROUPS=G1,G5,G20
JUDGE_TEMPERATURE=0
JUDGE_MAX_RETRIES=3
JUDGE_REQUEST_TIMEOUT=600
