# Copy this file to deploy/local/bailian_qwen35plus.env and fill in your own values.

# Required: DashScope / Bailian API key.
OPENAI_API_KEY=

# Default China-region OpenAI-compatible endpoint for Bailian.
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Official Qwen 3.5 Plus model name.
OPENAI_MODEL=qwen3.5-plus

# Required for JSON-mode judging on qwen3.5-plus.
OPENAI_EXTRA_BODY_JSON={"enable_thinking":false}

# Optional defaults used by the wrapper scripts.
JUDGE_INPUT_DIR=outputs/sae_eval_full_max
JUDGE_OUTPUT_DIR=
JUDGE_TOP_LATENTS=20
JUDGE_TOP_N=10
JUDGE_CONTROL_N=5
JUDGE_GROUPS=G1,G5,G20
JUDGE_TEMPERATURE=0
JUDGE_MAX_RETRIES=3
JUDGE_REQUEST_TIMEOUT=600
OPENAI_HTTP_TIMEOUT=600
